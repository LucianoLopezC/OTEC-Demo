# ════════════════════════════════════════════════════════════════════════════
# .htaccess — Carpeta /uploads/
# Bloquea el acceso directo a archivos — solo se sirven via download.php
# ════════════════════════════════════════════════════════════════════════════

Options -Indexes
Deny from all

# Bloquear ejecución de PHP dentro de uploads (seguridad crítica)
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
  Deny from all
</FilesMatch>
